# Supabase auth (soft gate: sign in to save/share comparisons).
# Both values are PUBLIC client config — the publishable key is meant to be
# exposed to browsers; RLS on saved_comparisons is what enforces ownership.
# Copy to .env for local dev; set the same as build env vars in Cloudflare.
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Anonymous, cookieless PostHog pageview analytics (optional). Create a dedicated
# project and paste its Project API Key. Leave the key blank to disable analytics.
PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxx
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
